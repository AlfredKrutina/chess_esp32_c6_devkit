{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://czechmate.local/openings_catalog.schema.json",
  "title": "CZECHMATE Opening Trainer Catalog",
  "type": "object",
  "required": ["version", "openings"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "locale_default": { "type": "string", "minLength": 2 },
    "curricula": {
      "type": "array",
      "items": { "$ref": "#/definitions/curriculum" }
    },
    "openings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/opening" }
    }
  },
  "definitions": {
    "localized": {
      "type": "object",
      "required": ["cs", "en"],
      "additionalProperties": false,
      "properties": {
        "cs": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "rationale": {
      "type": "object",
      "required": ["why_this_line", "instead_of"],
      "additionalProperties": false,
      "properties": {
        "summary": { "$ref": "#/definitions/localized" },
        "why_this_line": { "$ref": "#/definitions/localized" },
        "instead_of": { "$ref": "#/definitions/localized" },
        "when_to_play": { "$ref": "#/definitions/localized" },
        "related_line_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "maxItems": 4
        }
      }
    },
    "curriculum": {
      "type": "object",
      "required": ["id", "name", "line_ids"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "name": { "$ref": "#/definitions/localized" },
        "line_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "opening": {
      "type": "object",
      "required": [
        "id",
        "eco",
        "name",
        "side",
        "difficulty",
        "start_fen",
        "line_uci",
        "player_ply_indices"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "eco": { "type": "string", "minLength": 1 },
        "family": { "type": "string" },
        "name": { "$ref": "#/definitions/localized" },
        "side": { "enum": ["white", "black"] },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "idea": { "$ref": "#/definitions/localized" },
        "rationale": { "$ref": "#/definitions/rationale" },
        "start_fen": { "type": "string", "minLength": 10 },
        "line_uci": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-h][1-8][a-h][1-8][qrbn]?$" },
          "minItems": 2,
          "maxItems": 16
        },
        "player_ply_indices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 1,
          "maxItems": 8
        },
        "checkpoint_ply_indices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "maxItems": 4
        },
        "mirror_line_id": { "type": "string" },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "steps": { "type": "array" },
        "opponent_annotations": { "type": "array" },
        "common_mistakes": {
          "type": "array",
          "maxItems": 4,
          "items": { "$ref": "#/definitions/common_mistake" }
        }
      }
    },
    "common_mistake": {
      "type": "object",
      "required": ["wrong_uci", "at_ply_index", "hint"],
      "additionalProperties": false,
      "properties": {
        "wrong_uci": {
          "type": "string",
          "pattern": "^[a-h][1-8][a-h][1-8][qrbn]?$"
        },
        "at_ply_index": { "type": "integer", "minimum": 0 },
        "hint": { "$ref": "#/definitions/localized" }
      }
    }
  }
}
