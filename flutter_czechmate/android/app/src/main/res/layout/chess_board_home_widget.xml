<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chess_home_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chess_home_widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chess_home_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="CzechMate"
            android:textColor="#1C1C1E"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/chess_home_transport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="#E8E8ED"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="#3C3C43"
            android:textSize="11sp"
            tools:text="BLE" />
    </LinearLayout>

    <TextView
        android:id="@+id/chess_home_phase_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#636366"
        android:textSize="12sp"
        tools:text="Blitz · moves 12" />

    <LinearLayout
        android:id="@+id/chess_home_clocks_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♔"
                android:textColor="#8E8E93"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/chess_home_white_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#1C1C1E"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="5:00" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♚"
                android:textColor="#8E8E93"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/chess_home_black_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#1C1C1E"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="5:00" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/chess_home_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#8E8E93"
        android:textSize="11sp"
        tools:text="Running" />
</LinearLayout>
