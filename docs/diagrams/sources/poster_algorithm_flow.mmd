    LA1(" "):::legN
    LA2(" "):::legN
    LB1(" "):::legN
    LB2(" "):::legN
    LA1 -->|hlavni tok| LA2
    LB1 -.->|vol. spojeni| LB2
  end

  %% Propojeni
  APP -->|HTTP| WEBN
  APP -.->|BLE · net| BLEU
  
  DET --> GQ
  WEBN --> GQ
  BLEU --> GQ
  UART --> GQ
  
  GQ --> GAME
  GAME --> LEDT
  GAME -.-> MTX

  %% Zarovnani nepripojenych casti dospod
