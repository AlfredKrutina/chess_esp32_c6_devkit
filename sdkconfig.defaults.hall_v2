# Hall V2 + STM32 auto-flash profil (testovací / výrobní deska s I2C Hall segmenty).
# Použití:
#   idf.py -D SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.hall_v2" build flash
#
# GPIO níže jsou pro V2 desku bez reed multiplexu na SDA/SCL — NEPOUŽÍVAT na V1 LaskaKit
# (tam jsou GPIO10/11 řádky matice). Viz docs/reference/ZAPOJENI_ESP_STM4.md

# Matrix vstup přes I2C Hall (STM32 slave)
# CONFIG_CHESS_MATRIX_INPUT_GPIO_REED is not set
CONFIG_CHESS_MATRIX_INPUT_I2C_HALL=y

# Hall I2C — dedikované piny (bez kolize s reed řádky 10/11)
CONFIG_CHESS_HALL_I2C_SDA_GPIO=12
CONFIG_CHESS_HALL_I2C_SCL_GPIO=13
CONFIG_CHESS_HALL_I2C_FREQ_HZ=100000
CONFIG_CHESS_HALL_SEGMENT_COUNT=1

# STM32 ROM bootloader z ESP (AN4221)
CONFIG_CHESS_STM32_I2C_BL_ENABLE=y
CONFIG_CHESS_STM32_BL_SHARE_I2C_HALL=y
CONFIG_CHESS_STM32_BL_SHARED_I2C_FREQ_HZ=100000
CONFIG_CHESS_STM32_BL_AUTO_FLASH_ON_BOOT=y
CONFIG_CHESS_STM32_BL_AUTO_USE_BOOT0=y
CONFIG_CHESS_STM32_BL_BOOT0_GPIO=14
CONFIG_CHESS_STM32_BL_NRST_GPIO_SEG0=15
CONFIG_CHESS_STM32_BL_NRST_GPIO_SEG1=-1
CONFIG_CHESS_STM32_BL_NRST_GPIO_SEG2=-1
CONFIG_CHESS_STM32_BL_NRST_GPIO_SEG3=-1
CONFIG_CHESS_STM32_BL_POST_NRST_DELAY_MS=150
CONFIG_CHESS_STM32_BL_APP_BOOT_SETTLE_MS=150
CONFIG_CHESS_STM32_BL_HALL_PROBE_RETRIES=5
CONFIG_CHESS_STM32_BL_HALL_PROBE_RETRY_MS=100
CONFIG_CHESS_STM32_BL_GO_AFTER_FLASH=y
CONFIG_CHESS_STM32_BL_VERIFY_HALL_AFTER_FLASH=y
CONFIG_CHESS_STM32_BL_REFLASH_IF_HALL_MISSING=y
