# =============================================================================
# Nativní iOS (Xcode) — v remote jen Flutter klient flutter_czechmate/
# =============================================================================
/CZECHMATE/

# =============================================================================
# Podklady pro AI / interní plány — nejsou součástí hlavní dokumentace v remote
# (zdroj pravdy pro lidi: kořenové README.md + docs/README.md + reference/ + diagrams/)
# =============================================================================
# Cursor IDE — lokální plány agentů, náhledy chatů, workspace cache (nesdílet)
.cursor/

# Složky „context“ kam dáváš soubory pro AI (kořen i např. flutter_czechmate/context/)
**/context/

/docs/archive/
/docs/planning/

# Lokální backlog / nápady na diagramy (necommitovat — dlouhý osobní seznam)
/docs/diagrams/LOCAL_DIAGRAM_BACKLOG.md

# Volitelné osobní plány mimo docs/planning (např. export z nástroje)
**/*.local.plan.md

# Osobní learning plán (kořen projektu)
/LEARNING_PLAN.md


# =============================================================================
# ESP-IDF / toolchain
# =============================================================================
# Kořenový výstup `idf.py build` — nikdy commitovat. Pokud už historicky ve sledování:
#   git rm -r --cached build/
/build/

# Lokální CMake výstup omylem spuštěný uvnitř komponenty (IDE / debug)
components/*/build/

/sdkconfig.old

# Doxygen výstup (generuj: ./generate_docs.sh)
/docs/doxygen/html/
/docs/doxygen/rtf/
/docs/doxygen/latex/
/docs/doxygen/*.tag
/docs/doxygen/generation.log
/docs/doxygen/doxygen_warnings.log

# ESP-IDF — závislosti z Component Manageru (obnovíš: idf.py build / reconfigure)
/managed_components/

# GitHub Pages: statické soubory pro nasazení + README; zbytek generuje CI (Doxygen/Mermaid)
/gh-pages-ready/*
!/gh-pages-ready/README.md
!/gh-pages-ready/.nojekyll
!/gh-pages-ready/downloads.html
!/gh-pages-ready/landing/
!/gh-pages-ready/landing/**/*

# Lokální šum
*.log
# =============================================================================
# STM32 — lokální STM32CubeC0 (ST CMSIS + LL/HAL). Build: firmware/stm32_hall_c031/Makefile
# očekává `firmware/STM32CubeC0` (git clone ST repo sem), do Gitu nedávat.
# =============================================================================
/firmware/STM32CubeC0/

# =============================================================================
# Ostatní
# =============================================================================
.vscode/
.idea/
.DS_Store
*.swp
*~
