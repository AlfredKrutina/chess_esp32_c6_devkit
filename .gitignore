# =============================================================================
# Nativní iOS (Xcode) — v remote jen Flutter klient flutter_czechmate/
# =============================================================================
/CZECHMATE/

# =============================================================================
# Podklady pro AI / interní plány — nejsou součástí hlavní dokumentace v remote
# (zdroj pravdy pro lidi: kořenové README.md + docs/README.md + reference/ + diagrams/)
# =============================================================================
/context/

/docs/archive/
/docs/planning/

# Lokální backlog / nápady na diagramy (necommitovat — dlouhý osobní seznam)
/docs/diagrams/LOCAL_DIAGRAM_BACKLOG.md


# =============================================================================
# ESP-IDF / toolchain
# =============================================================================
# Kořenový výstup `idf.py build` — nikdy commitovat. Pokud už historicky ve sledování:
#   git rm -r --cached build/
/build/

# Lokální CMake výstup omylem spuštěný uvnitř komponenty (IDE / debug)
components/*/build/

/sdkconfig.old

# Doxygen výstup (generuj: ./generate_docs.sh)
/docs/doxygen/html/
/docs/doxygen/rtf/
/docs/doxygen/latex/
/docs/doxygen/*.tag
/docs/doxygen/generation.log
/docs/doxygen/doxygen_warnings.log

# ESP-IDF — závislosti z Component Manageru (obnovíš: idf.py build / reconfigure)
/managed_components/

# GitHub Pages: v main jen poznámky; HTML nasazuje CI z Doxygen + Mermaid
/gh-pages-ready/*
!/gh-pages-ready/README.md
!/gh-pages-ready/.nojekyll

# Lokální šum
*.log
# =============================================================================
# Ostatní
# =============================================================================
.vscode/
.idea/
.DS_Store
*.swp
*~
