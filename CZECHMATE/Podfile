# MediaPipe LLM Inference (Gemma 2B .bin) — viz https://ai.google.dev/edge/mediapipe/solutions/genai/llm_inference/ios
# Po `pod install` otevři CZECHMATE.xcworkspace (ne .xcodeproj).

platform :ios, '16.0'

target 'CZECHMATE' do
  use_frameworks!
  pod 'MediaPipeTasksGenAI'
  pod 'MediaPipeTasksGenAIC'

  target 'CZECHMATETests' do
    # @testable import CZECHMATE potřebuje stejné framework search paths / link jako host (MediaPipe).
    inherit! :complete
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
    end
  end

  # Simulátor: CocoaPods přidává -force_load libMediaPipeTasksGenAIC_simulator.a — globální C++ inicializátory
  # často spustí absl LOG(FATAL) dřív, než XCTest naváže spojení (pád hosta při `xcodebuild test`).
  # Bez force_load zůstanou frameworky MediaPipeTasksGenAI/C linkované přes OTHER_LDFLAGS; na zařízení
  # zůstává force_load pro device .a beze změny. Lokální Gemma na simulátoru může být i tak nepodporovaná — aplikace ale nastartuje a unit testy doběhnou.
  pods_support = File.join(installer.sandbox.root, 'Target Support Files')
  Dir.glob(File.join(pods_support, 'Pods-CZECHMATE*/Pods-CZECHMATE*.xcconfig')).each do |path|
    text = File.read(path)
    stripped = text.gsub(
      /^OTHER_LDFLAGS\[sdk=iphonesimulator\*\]\s*=\s*\$\(inherited\)\s+-force_load[^\n]+\n/,
      "OTHER_LDFLAGS[sdk=iphonesimulator*] = $(inherited)\n"
    )
    next if stripped == text

    File.write(path, stripped)
    STDERR.puts "[Podfile] Stripped MediaPipe simulator force_load in #{File.basename(File.dirname(path))}/#{File.basename(path)}"
  end
end
